# HuggingFace token — needed to download gated/private models.
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: override the default text-to-image model.
# Default is Tongyi-MAI/Z-Image-Turbo (fast, guidance-free).
# MODEL_ID=Tongyi-MAI/Z-Image-Turbo

# Optional: enable flash-attn kernel (only on HF Spaces ZeroGPU).
# USE_FLASH_ATTN=0

# Optional: minimum age for the entry age-gate (default 18, clamped to >= 18).
# This only changes what the visitor must confirm before entering the UI.
# It does NOT affect the prohibition on generating minors, which is fixed.
# MIN_AGE=18

# Optional: local Gradio server config.
# GRADIO_SERVER_NAME=0.0.0.0
# GRADIO_SERVER_PORT=7860
